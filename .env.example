# Desenvolvimento local: copie para .env (não commite)
VITE_API_BASE_URL=http://localhost:8080

# Google Sign-In (opcional): Client ID do projeto no Google Cloud Console
# VITE_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com

# Produção (Railway/Docker): defina no serviço do frontend:
#   VITE_API_BASE_URL  = URL da API (ex.: https://sua-api.railway.app)
#   VITE_GOOGLE_CLIENT_ID = Client ID do Google (mesmo valor do backend GOOGLE_CLIENT_ID)
# O Dockerfile usa essas variáveis no build; sem VITE_GOOGLE_CLIENT_ID o botão "Entrar com Google" não aparece.
