# ===========================================
# Desenvolvimento local (npm run dev)
# ===========================================
# Copie para .env e não commite (já está no .gitignore).
#
# A URL deve ser a do backend; o app adiciona /api automaticamente.

VITE_API_BASE_URL=http://localhost:8080


# ===========================================
# Produção (Railway / Docker)
# ===========================================
# Com deploy via Docker, o build NÃO recebe variáveis do Railway.
# Use sempre API_BASE_URL (runtime) no serviço do FRONTEND:
#
#   Nome:  API_BASE_URL
#   Valor: https://sua-api.up.railway.app/api
#
# O entrypoint gera /env.js na subida do container com esse valor.
