# ===========================================
# Desenvolvimento local (npm run dev)
# ===========================================
# Copie para .env e não commite (já está no .gitignore).
#
# A URL deve ser a do backend; o app adiciona /api automaticamente.

VITE_API_BASE_URL=http://localhost:8080


# ===========================================
# Produção (Railway / Docker)
# ===========================================
# Use UMA das opções no serviço do FRONTEND (masd-caixa-web):
#
# Opção A — Build (recomendado, mais estável):
#   Nome:  VITE_API_BASE_URL
#   Valor: https://sua-api.up.railway.app/api
#   (No Railway, defina como variável do serviço; no deploy o build usa esse valor.)
#
# Opção B — Runtime (permite trocar URL sem rebuild):
#   Nome:  API_BASE_URL
#   Valor: https://sua-api.up.railway.app/api
#   (O entrypoint do container gera /env.js com esse valor na subida.)
